# Application Configuration
APP_NAME="POS & Stock"
APP_ENV=production
APP_URL=https://your-username-your-space.hf.space
APP_DEBUG=false

# Production URL (set to your Hugging Face Space URL)
PROD_APP_URL=https://your-username-your-space.hf.space

# These are auto-generated by start.sh when MySQL runs inside Docker.
# For external MySQL, set these as Hugging Face Space Secrets:
#   PROD_DB_HOSTNAME, PROD_DB_USERNAME, PROD_DB_PASSWORD, PROD_DB_DATABASE
PROD_DB_HOSTNAME=
PROD_DB_USERNAME=
PROD_DB_PASSWORD=
PROD_DB_DATABASE=

# Optional ImageKit credentials (for image uploads)
# Set as Space Secrets if needed:
#   IMAGEKIT_PUBLIC_KEY, IMAGEKIT_PRIVATE_KEY, IMAGEKIT_URL_ENDPOINT
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=
